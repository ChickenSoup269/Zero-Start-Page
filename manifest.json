{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.8.2",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "permissions": ["bookmarks", "scripting", "tabs", "storage"],
  "icons": {
    "128": "icon/logo.png"
  },
  "action": {
    "default_title": "__MSG_extName__",
    "default_icon": {
      "128": "icon/logo.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "redirect.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.spotify.com/*",
        "*://*.zingmp3.vn/*",
        "*://mp3.zing.vn/*",
        "*://soundcloud.com/*",
        "*://*.soundcloud.com/*",
        "*://music.apple.com/*",
        "*://nhaccuatui.com/*",
        "*://*.nhaccuatui.com/*",
        "*://nct.vn/*",
        "*://*.nct.vn/*",
        "*://music.youtube.com/*"
      ],
      "js": ["content-media.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://suggestqueries.google.com/*",
    "*://*.youtube.com/*",
    "*://*.spotify.com/*",
    "*://*.zingmp3.vn/*",
    "*://mp3.zing.vn/*",
    "*://soundcloud.com/*",
    "*://*.soundcloud.com/*",
    "*://music.apple.com/*",
    "*://nhaccuatui.com/*",
    "*://*.nhaccuatui.com/*",
    "*://nct.vn/*",
    "*://*.nct.vn/*",
    "*://music.youtube.com/*",
    "*://images.google.com/*",
    "https://api.unsplash.com/*",
    "https://images.unsplash.com/*",
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://i.ytimg.com/*",
    "https://i.scdn.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' blob: data: https:; media-src 'self' blob: https://raw.githubusercontent.com; connect-src 'self' https://calendar.google.com https://api.unsplash.com https://images.unsplash.com https://api.open-meteo.com https://geocoding-api.open-meteo.com https://suggestqueries.google.com;"
  }
}
